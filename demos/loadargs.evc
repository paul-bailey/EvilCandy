/*
 * To test passing of args to a script, import this in interactive mode.
 *
 * Test 1:
 *      import('demos/loadargs.evc', 'x', ...bunch of args...);
 *      # expect to see a printout of args
 *
 * Test 2:
 *      let x = import('demos/loadargs.evc', 'r');
 *      x(...bunch of args...);
 *      # expect to see a printout of args
 */
let args = __optarg__;
let kwargs = __kwarg__;
print("positional args:", *args);
print("keyword args:", kwargs);
