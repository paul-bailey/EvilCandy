#!./evilcandy

// Print myself
(function(name) {
    try {
        let f = open(name, "r");
        let s;
        while (true) {
            s = f.readline();
            if (s == null || s == "")
                break;
            // each line should have its own nl
            print(s, end='');
        }
    } catch (e) {
        let type, msg = e;
        print('Got a', type, ':', msg);
    }
})("demos/cat.egq");

// : vim: set syntax=javascript :
