#!./evilcandy

// Print myself
(function(name) {
    try {
        let f = open(name, "r", encoding="utf-8");
        let s;
        while true {
            s = f.readline();
            if (s == null || s == "")
                break;
            // each line should have its own nl
            print(s, end='');
        }
    } catch (e) {
        print('Got a', e, ':', e.message);
    }
})("demos/cat.egq");

// : vim: set syntax=javascript :
