#!/usr/bin/env evilcandy
/*
 * Generated by OpenAI Codex, with small edits by human programmer.
 *
 * A small text adventure written to demonstrate user-defined classes.
 *
 * It shows:
 *   - named classes
 *   - inheritance
 *   - super()
 *   - methods mutating instance state
 *   - polymorphic dispatch through Item.use()
 *
 * Run:
 *      evilcandy demos/class_adventure.evc
 */

class Thing() {
    .__init__ = function(self, name, desc) {
        self.name = name;
        self.desc = desc;
    },

    .describe = function(self) {
        return self.desc;
    },

    .__str__ = function(self) {
        return self.name;
    },
}

class Item(Thing) {
    .use = function(self, game) {
        print(f'You cannot find a use for the {self.name}.');
    },
}

class Note(Item) {
    .__init__ = function(self, name, desc, text) {
        super().__init__(name, desc);
        self.text = text;
    },

    .use = function(self, game) {
        print(self.text);
    },
}

class Key(Item) {
    .__init__ = function(self, name, desc, target_name) {
        super().__init__(name, desc);
        self.target_name = target_name;
    },

    .use = function(self, game) {
        if (game.player.here == game.gate and !game.gate_open) {
            game.gate_open = true;
            game.gate.connect('north', game.lobby);
            print('The brass key turns with a brittle click. The iron gate opens.');
        } else if (game.gate_open) {
            print('The iron gate is already open.');
        } else {
            print(f'The {self.name} does not fit anything here.');
        }
    },
}

class Lamp(Item) {
    .use = function(self, game) {
        if (game.player.here == game.pond and !game.pond_lit) {
            game.pond_lit = true;
            print('The lamp glows green. The pond clears enough to search.');
        } else if (game.player.here == game.pond) {
            print('The lamp is already lighting the pond.');
        } else {
            print('The lamp flickers, but nothing nearby changes.');
        }
    },
}

class Coin(Item) {
    .use = function(self, game) {
        if (game.player.here == game.tower) {
            game.won = true;
            print('The square coin drops into the machine. The wrapping tower wakes,');
            print('prints one perfect candy, and goes quiet.');
            print('You win.');
        } else {
            print('The coin feels important, but this is not the place for it.');
        }
    },
}

class Room(Thing) {
    .__init__ = function(self, name, desc) {
        super().__init__(name, desc);
        self.exits = {};
        self.items = [];
    },

    .connect = function(self, direction, other) {
        self.exits[direction] = other;
    },

    .add_item = function(self, item) {
        self.items.append(item);
    },

    .find_item = function(self, name) {
        for item in self.items {
            if (item.name == name)
                return item;
        }
        return null;
    },

    .take_item = function(self, name) {
        let found = null;
        let kept = [];

        for item in self.items {
            if (found == null and item.name == name)
                found = item;
            else
                kept.append(item);
        }

        self.items = kept;
        return found;
    },

    .print_items = function(self) {
        if (length(self.items) == 0) {
            print('Nothing useful is lying around.');
            return null;
        }

        print('You can see: ', end='');
        for i in range(length(self.items)) {
            if (i > 0)
                print(', ', end='');
            print(self.items[i].name, end='');
        }
        print('');
    },

    .print_exits = function(self) {
        let directions = [];
        for direction in self.exits
            directions.append(direction);

        print('Exits: ', end='');
        for i in range(length(directions)) {
            if (i > 0)
                print(', ', end='');
            print(directions[i], end='');
        }
        print('');
    },

    .look = function(self, game) {
        print('');
        print(self.name);
        print(self.describe());

        if (self == game.gate and !game.gate_open)
            print('The iron gate is locked.');
        if (self == game.gate and game.gate_open)
            print('The iron gate stands open.');
        if (self == game.pond and !game.pond_lit)
            print('The pond is too dark to search safely.');

        self.print_items();
        self.print_exits();
    },
}

class Player() {
    .__init__ = function(self, start_room) {
        self.here = start_room;
        self.inventory = [];
    },

    .find_item = function(self, name) {
        for item in self.inventory {
            if (item.name == name)
                return item;
        }
        return null;
    },

    .has_item = function(self, name) {
        return self.find_item(name) != null;
    },

    .take = function(self, room, name) {
        let item = room.find_item(name);

        if (item == null) {
            print(f'There is no {name} here.');
            return null;
        }

        item = room.take_item(name);
        self.inventory.append(item);
        print(f'Taken: {item.name}.');
    },

    .drop = function(self, room, name) {
        let found = null;
        let kept = [];

        for item in self.inventory {
            if (found == null and item.name == name)
                found = item;
            else
                kept.append(item);
        }

        if (found == null) {
            print(f'You do not have {name}.');
            return null;
        }

        self.inventory = kept;
        room.add_item(found);
        print(f'Dropped: {found.name}.');
    },

    .show_inventory = function(self) {
        if (length(self.inventory) == 0) {
            print('You are carrying nothing.');
            return null;
        }

        print('You are carrying: ', end='');
        for i in range(length(self.inventory)) {
            if (i > 0)
                print(', ', end='');
            print(self.inventory[i].name, end='');
        }
        print('');
    },
}

class Game() {
    .__init__ = function(self) {
        self.gate_open = false;
        self.pond_lit = false;
        self.won = false;

        self.gate = Room('Iron Gate', 'The candy works stands north of you behind an iron gate. A cracked path runs east and west.');
        self.shed = Room('Tool Shed', 'Dusty shelves lean over a floor sticky with old sugar. A brass key hangs from a bent nail.');
        self.garden = Room('Sour Garden', 'Twisted mint bushes crowd the path. A glass lamp is half buried in the dirt.');
        self.pond = Room('Black Licorice Pond', 'A dark pond bubbles slowly. Something square glints under the surface.');
        self.lobby = Room('Factory Lobby', 'Broken turnstiles point toward a stairwell. The air smells like burnt sugar.');
        self.tower = Room('Wrapping Tower', 'Moonlight falls through the wrapping tower. A silent machine waits beside a coin slot.');

        self.gate.connect('east', self.shed);
        self.gate.connect('west', self.garden);
        self.shed.connect('west', self.gate);
        self.garden.connect('east', self.gate);
        self.garden.connect('north', self.pond);
        self.pond.connect('south', self.garden);
        self.lobby.connect('south', self.gate);
        self.lobby.connect('up', self.tower);
        self.tower.connect('down', self.lobby);

        self.gate.add_item(Note('note', 'A folded note stained with syrup.', 'The note says: "The gate key is where sweet things go to rust."'));
        self.shed.add_item(Key('key', 'A small brass key, sticky at the teeth.', 'gate'));
        self.garden.add_item(Lamp('lamp', 'A glass lamp. It glows when you shake it.'));
        self.pond.add_item(Coin('coin', 'A square candy coin, cold and heavy.'));

        self.player = Player(self.gate);
    },

    .look = function(self) {
        self.player.here.look(self);
    },

    .help = function(self) {
        print('Commands: look, inventory, go DIR, take ITEM, drop ITEM, use ITEM, help, quit');
        print('Short directions work too: north, south, east, west, up, down.');
    },

    .go = function(self, direction) {
        let exits = self.player.here.exits;

        if (!(direction in exits)) {
            print('You cannot go that way.');
            return null;
        }

        self.player.here = exits[direction];
        self.look();
    },

    .take_item = function(self, name) {
        if (name == '') {
            print('Take what?');
            return null;
        }

        if (self.player.here == self.pond and name == 'coin' and !self.pond_lit) {
            print('The coin is below the dark surface. You need more light first.');
            return null;
        }

        self.player.take(self.player.here, name);
    },

    .drop_item = function(self, name) {
        if (name == '') {
            print('Drop what?');
            return null;
        }

        self.player.drop(self.player.here, name);
    },

    .use_item = function(self, name) {
        if (name == '') {
            print('Use what?');
            return null;
        }

        let item = self.player.find_item(name);
        if (item == null) {
            print(f'You do not have {name}.');
            return null;
        }

        item.use(self);
    },

    .normalize_direction = function(self, word) {
        if (word == 'n')
            return 'north';
        if (word == 's')
            return 'south';
        if (word == 'e')
            return 'east';
        if (word == 'w')
            return 'west';
        if (word == 'u')
            return 'up';
        if (word == 'd')
            return 'down';
        return word;
    },

    .handle_command = function(self, line) {
        let words = line.strip().lower().split();
        if (length(words) == 0)
            return true;

        let verb = words[0];
        let noun = '';
        if (length(words) > 1)
            noun = words[1];

        if (verb == 'quit' or verb == 'q')
            return false;
        if (verb == 'look' or verb == 'l')
            self.look();
        else if (verb == 'help' or verb == '?')
            self.help();
        else if (verb == 'inventory' or verb == 'inv' or verb == 'i')
            self.player.show_inventory();
        else if (verb == 'take' or verb == 'get')
            self.take_item(noun);
        else if (verb == 'drop')
            self.drop_item(noun);
        else if (verb == 'use')
            self.use_item(noun);
        else if (verb == 'go')
            self.go(self.normalize_direction(noun));
        else if (verb in {'north', 'south', 'east', 'west', 'up', 'down', 'n', 's', 'e', 'w', 'u', 'd'})
            self.go(self.normalize_direction(verb));
        else
            print('I do not understand that command. Type "help" for options.');

        return !self.won;
    },
}

let game = Game();

print('The Licorice Lock, Class Edition');
print(f'Type "help" for commands. You are a {typeof(game.player)} in a world of user-defined classes.');
game.look();

while !game.won {
    let line = input('> ');
    if (!game.handle_command(line))
        break;
}
