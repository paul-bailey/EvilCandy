// class Test -

class Test() {
    '__init__': function(**kwargs) {
        let opts = {
            // TODO: isn't this what breadcrumbs are for?
            'FILE': sys.breadcrumbs[-1],
        } | kwargs;
        this.FILE = opts.FILE;
        // TODO: if TTY, add some pretty-output attributes
    },
    'AssertionError': ((message) => 'AssertionError', message),
    'assert_bool': function(condition, expect) {
        if (condition != expect) {
            let type = expect ? 'true' : 'false';
            throw this.AssertionError(f'assertion {type} failed');
        }
    },
    'assert_true': ((condition) => this.assert_bool(condition, true)),
    'assert_false': ((condition) => this.assert_bool(condition, false)),
    'code_throws_exception': function(code) {
        let threw_exception = false;
        try {
            eval(code);
        } catch(e) {
            // TODO: exceptions need to be a class, so we could
            // use instanceof to confirm which exception 'e' is.
            threw_exception = true;
        }
        return threw_exception;
    },
    'assert_exception': function(code) {
        if (!this.code_throws_exception(code))
            throw this.AssertionError(f'failed to throw exception');
    },
    'assert_no_exception': function(code) {
        if (this.code_throws_exception(code))
            throw this.AssertionError(f'threw exception when it shouldn\'t');
    },
    'assert_equal': function(a, b) {
        if (a != b)
            throw this.AssertionError(f'{a} not equal to {b}');
    },
};


return Test;
