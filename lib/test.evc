// class Test -

class TestException(RuntimeError) {}

function assertion_exception(self, message) {
    let msgstr = '';
    if (self.name)
        msgstr += f'{self.name} ';
    msgstr += f'in file{self.file}: ';
    msgstr += f'test #{self.test_number}: ';
    return TestException(msgstr + message);
}

function assert_bool(self, condition, expect) {
    if (condition != expect) {
        let type = expect ? 'true' : 'false';
        throw assertion_exception(self, f'assertion {type} failed');
    }
    self.test_number++;
}

function code_throws_exception(code) {
    let threw_exception = false;
    try {
        eval(code);
    } catch(e) {
        threw_exception = true;
    }
    return threw_exception;
}

function methodcall_throws_exception(obj, method_name, args) {
    let threw_exception = false;
    try {
        let method = getattr(obj, method_name);
        method(*args);
    } catch(e) {
        threw_exception = true;
    }
    return threw_exception;
}

class Test() {
    .__init__ = function(self, **kwargs) {
        let opts = {
            'file': sys['breadcrumbs'][-1],
            'name': null,
        } | kwargs;
        self.file = opts['file'].split(sep='/')[-1];
        self.name = opts['name'];
        self.test_number = 1;
    },

    .assert_true = function(self, condition) {
        assert_bool(self, condition, true);
    },

    .assert_false = function(self, condition) {
        assert_bool(self, condition, false);
    },

    .assert_exception = function(self, code) {
        if (!code_throws_exception(code))
            throw assertion_exception(self, f'failed to throw exception');
        self.test_number++;
    },

    .assert_no_exception = function(self, code) {
        if (code_throws_exception(code))
            throw assertion_exception(
                            self, f'threw exception');
        self.test_number++;
    },

    .assert_equal = function(self, a, b) {
        if (a != b)
            throw assertion_exception(self, f'{a} not equal to {b}');
        self.test_number++;
    },

    .reset = function(self, **kwargs) {
        if 'name' in kwargs
            self.name = kwargs['name'];
        self.test_number = 1;
    },

    .assert_exception_inscope = function(self, obj, method_name, args) {
        if (!methodcall_throws_exception(obj, method_name, args))
            throw assertion_exception(self, f'failed to throw exception');
    },

    .assert_no_exception_inscope = function(self, obj, method_name, args) {
        if (methodcall_throws_exception(obj, method_name, args))
            throw assertion_exception(self, f'threw exception');
    },
}

return Test;
