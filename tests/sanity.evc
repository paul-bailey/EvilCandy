// sanity test.  run when making changes to code
// to make sure I didn't break anything.

let Test = importfile('../lib/test.evc');

function test_generator() {
    let test = Test(name='GeneratorTest');
    function test_generator_1() {
        function get_iterator(stop) {
            return (start) => {
                for i in range(start, stop)
                    yield i;
            };
        }

        let toten = get_iterator(10);

        test.assert_true(list(toten(4))
                         == [4, 5, 6, 7, 8, 9]);
        test.assert_true(list(toten(10)) == []);
    }
    function test_generator_2() {
        function get_iterator_1() {
            yield 'a';
            yield 'b';
            yield 'c';
        }
        function get_iterator_2() {
            for letter in get_iterator_1() {
                yield letter;
            }
        }
        test.assert_true(list(get_iterator_1()) == ['a', 'b', 'c']);
        // See issue #64: .join() won't permit generators right now.
        // test.assert_true(''.join(get_iterator_2()) == 'abc');
        test.assert_true(list(get_iterator_2()) == ['a', 'b', 'c']);
    }
    test_generator_1();
    test_generator_2();
}

function test_string() {
    let test = Test(name='StringTest');
    function test_replace() {
        test.reset(name='string.replace()');
        test.assert_true('this'.replace('is', 'at') == 'that');
    }
    function test_partition() {
        test.reset(name='string.partition()');
        test.assert_true('this'.partition('i') == ('th', 'i', 's'));
        test.assert_true('this'.partition('s') == ('thi', 's', ''));
    }
    function test_split() {
        test.reset(name='string.split()');
        test.assert_true('a b c'.split() == ['a', 'b', 'c']);
        test.assert_true(' abc'.split() == ['abc']);
        test.assert_true('abc '.split() == ['abc']);
        test.assert_true('a b c'.split(sep=' ') == ['a', 'b', 'c']);
        test.assert_true('a//b///c/d'.split(sep='/')
                         == ['a', '', 'b', '', '', 'c', 'd']);
        test.assert_true('a//b///c/d'.rsplit(sep='/')
                         == ['a', '', 'b', '', '', 'c', 'd']);
        test.assert_true('a//b///c/d'.split(sep='/', maxsplit=1)
                         == ['a', '', 'b///c/d']);
        test.assert_true('a//b///c/d'.rsplit(sep='/', maxsplit=1)
                         == ['a//b///c', 'd']);
    }
    function test_count() {
        let uni, str, abc;
        test.reset(name='string.count()');
        test.assert_true('a b c'.count(' ') == 2);
        uni = '\u1234';
        str = 'a' + uni + 'b' + 2 * uni + 'c' + uni;
        test.assert_true(str.count(uni) == 4);
        abc = 'abc';
        str = uni.join(list(abc));
        test.assert_true(str.count(uni) == length(abc)-1);
    }
    function test_rstring() {
        test.assert_true(r'\\' == '\\\\');
        test.assert_true(r'\n' == '\\n');
        test.assert_true(r'\'' == '\'');
    }
    test_replace();
    test_partition();
    test_split();
    test_count();
    test_rstring();
}

function test_dict() {
    let test = Test(name='DictTest');
    let d = {};
    test.assert_true(length(d) == 0);
    d['a'] = 1;
    d['b'] = 2;
    test.assert_true(length(d) == 2);
    test.assert_true(d == { 'a': 1, 'b': 2 });
    test.assert_true(d !== { 'a': 1, 'b': 2 });
    delete d['a'];
    test.assert_true(length(d) == 1);
    test.assert_true(d == { 'b': 2 });
    let e = d.copy();
    test.assert_true(d == e);
    test.assert_true(d !== e);
    test.assert_true('b' in d);
    d.clear();
    // shallow copy means change d does not affect e
    test.assert_true(d != e);
    test.assert_true(d == {});
    // order-of-operations gotcha: '==' takes precedence
    // over bitwise '|', so the parentheses are needed.
    test.assert_true((d | e) == {'b': 2});
    test.assert_true(list(d) == []);
    test.assert_true(list(e) == ['b']);
    // insertion order should not matter
    test.assert_true({'a': 1, 'b': 2} == {'b': 2, 'a': 1});
}

function test_list() {
    let test = Test(name='ListTest');
    let a = list(range(5));
    test.assert_true(a == [0, 1, 2, 3, 4]);
    test.assert_true(a[:] !== a);
    test.assert_true(a[-1:0] == []);
    test.assert_true(a[0:10] == a);
    test.assert_true(a[10:20] == []);
    test.assert_true(3*[] == []);
    test.assert_true(3*[1] == [1, 1, 1]);
    test.assert_exception("['a', 1] > [1, 'a']");
    test.assert_no_exception("[2, 1] > [1, 2]");
    test.assert_no_exception("['a', 1] > ['a', 2]");
}

function test_set() {
    let test = Test(name='SetTest');
    let a = { 0, 1, 2, 3, };
    let b = { 3, 4, 5 };
    test.assert_true((a | b) == set(range(6)));
    test.assert_true((a ^ b) == { 0, 1, 2, 4, 5 });
    test.assert_true((a - b) == { 0, 1, 2 });
    test.assert_true((a & b) == { 3 });
    // insertion order should not matter
    test.assert_true({1, 2} == {2, 1});
    test.assert_true(set('abbadabba') == {'a', 'b', 'd'});
}

function test_eval() {
    let test = Test(name='eval()');
    test.assert_true(eval('__gbl__') == __gbl__);
    test.assert_true(eval('__gbl__') === __gbl__);
    test.assert_true(eval('1 + 2') == 3);
    test.assert_exception('a + b');
    test.assert_exception('1 + ,');
    // namespace should not be passed to eval
    test.assert_exception('test;');
}

function test_randos() {
    let test = Test(name='randos');
    test.assert_true('_builtins' in __gbl__);

    // gh issue 69
    test.assert_true(eval('(0 or 1) + 2') == 3);
    test.assert_true(eval('(5 or 1) + 2') == 7);
    test.assert_true(eval('(0 and 1) + 2') == 2);
    test.assert_true(eval('(5 and 1) + 2') == 3);

}

function test_class() {
    let test = Test(name='class');
    {
        class MyClass() { }
        let x = MyClass();
        test.assert_exception_inscope(x, 'anything', []);
    }
    {
        class MyClass() { .hello = (self) => 'world' }
        let x = MyClass();
        test.assert_no_exception_inscope(x, 'hello', []);
        test.assert_true(x.hello() == 'world');
    }
    {
        class MyClass() {
            .__init__ = function (self, x) {
                self.x = x;
            }
        }
        let x = MyClass(12);
        test.assert_true(x.x == 12);
    }

    // make sure instance B does not change instance A data
    {
        class MyClass() {
            .x = 12,
        }
        let a = MyClass();
        let b = MyClass();
        a.x++;
        test.assert_true(b.x == 12);
        test.assert_true(a.x == 13);
        test.assert_true(a instanceof MyClass);
        test.assert_false(a instanceof string);
        test.assert_exception('1 instanceof 1');
    }

    // check behavior of instanceof with inheritance and delegation
    {
        class A() { .x = (self) => 1 }
        class B(A) {}
        class C by notx () {
            .__init__ = function(self) {
                self.notx = A();
            }
        }

        let b = B();
        let c = C();

        test.assert_true(b instanceof A);
        test.assert_false(c instanceof A);
        test.assert_true(typeof(b) == 'B');
        test.assert_true(typeof(c) == 'C');
        test.assert_true(b.x() == 1);
        test.assert_true(c.x() == 1);

        // dynamic changing of delegate
        c.notx = 'some_string';
        test.assert_true(c.startswith('some'));
    }

    // TODO: This is temporary; we may add support for inheriting
    // built-in types in the future.
    {
        let exc = null;
        try {
            class A(string) {}
        } catch (e) {
            exc = e;
        }
        test.assert_true(exc instanceof NotImplementedError);
    }

    // check behavior of 'private'
    {
        class A() {
            private .x = 1,
            .get_x = function(self) {
                return self.x;
            }
        }
        class B(A) {
            .b_get_x = function(self) {
                return self.x;
            }
        }

        class C by a () {
            .__init__ = function(self) {
                self.a = A();
            }
        }

        let exc;
        let a = A();
        let b = B();
        let c = C();

        // .get_x called as a method of A(), so no exception.
        exc = false;
        try {
            let x = a.get_x();
        } catch (e) {
            exc = true;
        }
        test.assert_false(exc);

        // Throw an exception for inherited .get_x()
        // TODO: Bad policy. See gh issue #68.  This might change.
        exc = false;
        try {
            let x = b.get_x();
        } catch (e) {
            exc = true;
        }
        test.assert_true(exc);

        // c.get_x() is really c.a.get_x(), so expect no exception
        exc = false;
        try {
            let x = c.get_x();
        } catch (e) {
            exc = true;
        }
        test.assert_false(exc);

        // Do not allow access through .b_get_x(), which is not a method
        // of A()
        exc = false;
        try {
            let x = b.b_get_x();
        } catch (e) {
            exc = true;
        }
        test.assert_true(exc);

        // All remaining dereference .x from this function (not a method
        // of A, so throw exception.

        exc = false;
        try {
            let x = a.x;
        } catch (e) {
            exc = true;
        }
        test.assert_true(exc);

        exc = false;
        try {
            let x = b.x;
        } catch (e) {
            exc = true;
        }
        test.assert_true(exc);

        exc = false;
        try {
            let x = c.x;
        } catch (e) {
            exc = true;
        }
        test.assert_true(exc);
    }
}

let tests = [
    ('test_generator',   test_generator),
    ('test_string',      test_string),
    ('test_dict',        test_dict),
    ('test_list',        test_list),
    ('test_set',         test_set),
    ('test_eval',        test_eval),
    ('test_class',       test_class),
    ('test_randos',      test_randos),
];

for name, test in tests {
    print(f'{name:-16}: ', end='');
    test();
    print('success');
}

